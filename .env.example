# ==============================================================
# WingMatch — 환경변수 템플릿
# ==============================================================
#
# 사용법:
#   cp .env.example .env.local
#   .env.local을 열어서 실제 값으로 교체
#
# ⚠️  .env.local은 절대 Git에 커밋하지 마세요!
#      .gitignore에 .env*.local이 포함되어 있는지 확인하세요.
#
# 값을 얻는 방법:
#   Supabase → 프로젝트 선택 → Settings → API
# ==============================================================


# ──────────────────────────────────────────────────────────────
# Supabase — 필수 (앱이 동작하려면 반드시 설정)
# ──────────────────────────────────────────────────────────────

# Supabase 프로젝트 URL
# 예시: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Supabase Anon (공개) 키 — 클라이언트 측에서 사용
# RLS(Row Level Security)로 보호되므로 공개해도 안전
# 예시: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key


# ──────────────────────────────────────────────────────────────
# Supabase — 서버 전용 (절대 클라이언트에 노출 금지)
# ──────────────────────────────────────────────────────────────

# Supabase Service Role 키 — RLS 우회 (관리자 권한)
# ⚠️  NEXT_PUBLIC_ 접두사 없이 사용 (브라우저 번들에 포함되지 않음)
# 사용처: 향후 Admin API, DB 트리거 대안, 크론 작업 등
# 예시: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase JWT Secret — 토큰 직접 검증 시 사용 (선택)
# Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your_supabase_jwt_secret


# ──────────────────────────────────────────────────────────────
# Next.js — 앱 URL
# ──────────────────────────────────────────────────────────────

# 배포된 앱의 실제 URL (Vercel 배포 후 교체)
# 로컬 개발 시: http://localhost:3000
# Vercel 배포 시: https://wingmatch.vercel.app (또는 커스텀 도메인)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel이 자동으로 설정하는 배포 URL (Vercel 환경에서만 사용됨)
# 수동 설정 불필요 — Vercel이 자동 주입
# VERCEL_URL=your-deployment.vercel.app


# ──────────────────────────────────────────────────────────────
# Supabase OAuth — Google 로그인 (선택)
# ──────────────────────────────────────────────────────────────
#
# 설정 방법:
#   1. Google Cloud Console → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID 생성
#   2. 승인된 리디렉션 URI 추가:
#      https://<your-project>.supabase.co/auth/v1/callback
#   3. Supabase Dashboard → Authentication → Providers → Google
#      Client ID와 Client Secret 입력
#
# ⚠️  이 값들은 Supabase 대시보드에서 설정하며
#      Next.js 환경변수로는 필요 없습니다.
#      (참고용으로만 기재)
#
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret


# ──────────────────────────────────────────────────────────────
# 이미지 스토리지 (선택)
# ──────────────────────────────────────────────────────────────

# Supabase Storage 버킷 이름 (프로필 사진 업로드용)
# Supabase Dashboard → Storage → New bucket
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=card-photos


# ──────────────────────────────────────────────────────────────
# 분석 / 모니터링 (선택 — Week 5 이후)
# ──────────────────────────────────────────────────────────────

# Vercel Analytics (자동 활성화, 별도 키 불필요)
# Vercel Dashboard → Analytics 탭에서 활성화

# Sentry 에러 모니터링 (선택)
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
# SENTRY_AUTH_TOKEN=your_sentry_auth_token
# SENTRY_ORG=your_sentry_org
# SENTRY_PROJECT=wingmatch


# ──────────────────────────────────────────────────────────────
# 개발 전용 (production에서는 설정 불필요)
# ──────────────────────────────────────────────────────────────

# Next.js 개발 서버 포트 (기본: 3000)
# PORT=3000

# Supabase 로컬 개발 (supabase start로 로컬 인스턴스 실행 시)
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_local_anon_key
